{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "editor.suggest.preview": true,
  "editor.inlineSuggest.minShowDelay": 1,
  "editor.quickSuggestionsDelay": 1,

  "files.autoSave": "onFocusChange",

  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "npm.enableRunFromFolder": true,
  "npm.scriptExplorerAction": "run",

  "typescript.tsdk": "node_modules/typescript/lib",

  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "graphql"],
  "eslint.options": {},
  "eslint.workingDirectories": [
    {
      "mode": "auto",
      "changeProcessCWD": true
    },
    { "directory": "./apps/**/*", "changeProcessCWD": true },
    { "directory": "./packages/**/*", "changeProcessCWD": true },
  ],
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": "commit-message-guidelines.md",
      "text": "Use this file as a reference for writing commit messages. It contains detailed guidelines and examples for conventional commits, including types, scopes, and formatting. Follow the structure provided in the file to ensure your commit messages are clear, concise, and informative."
    }
  ],
}