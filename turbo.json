{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "build/**"],
      "outputLogs": "new-only"
    },
    "lint": {},
    "type-check": {},
    "test": {},
    "clean": {
      "cache": false
    },
     "start": {
      "cache": false,
      "persistent": true
    }
  }
}
